# ==========================================
# RULES FOR FRONTEND (React / Expo / Native)
# ==========================================

# dependencies
Frontend/node_modules/

# Expo
Frontend/.expo/
Frontend/dist/
Frontend/web-build/
Frontend/expo-env.d.ts

# Native
Frontend/.kotlin/
Frontend/*.orig.*
Frontend/*.jks
Frontend/*.p8
Frontend/*.p12
Frontend/*.key
Frontend/*.mobileprovision

# Metro
Frontend/.metro-health-check*

# debug
Frontend/npm-debug.*
Frontend/yarn-debug.*
Frontend/yarn-error.*

# macOS
Frontend/.DS_Store
Frontend/*.pem

# local env files
Frontend/.env*.local

# typescript
Frontend/*.tsbuildinfo

Frontend/example

# generated native folders
Frontend/ios/
Frontend/android/